# Local reference copy of the original app. Keep it accessible, but do not
# vendor the old repository into the rebuilt app's Git history.
sightlines-old/

# macOS
.DS_Store

# Dependencies and build output
# (both forms: the trailing-slash pattern matches only real directories, so a
# node_modules *symlink* — e.g. in a worktree — would otherwise get tracked)
node_modules
node_modules/
dist/
build/
.next/
.astro/
coverage/

# Local environment files
.env
.env.*
!.env.example

# Local agent/editor tooling
.codex/
.claude/
.agents/
agent/skills/
.impeccable/
skills-lock.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.superpowers/
.playwright-mcp/
