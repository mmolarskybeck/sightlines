---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="This page doesn't exist.">
  <main class="page-main">
    <p class="kicker">404</p>
    <h1 class="page-title">This wall is empty</h1>
    <p class="lede">
      The page you're looking for doesn't exist. It may have moved, or the
      address may have a typo.
    </p>
    <div class="prose">
      <p>
        Try the <a href="/">home page</a>, or open the app at
        <a href="https://app.sightlines.art/">app.sightlines.art</a>.
      </p>
    </div>
  </main>
</BaseLayout>
